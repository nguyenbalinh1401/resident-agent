# =============================================================================
# Resident Agent - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
DEBUG=false

# -----------------------------------------------------------------------------
# Redis Configuration (REQUIRED for conversation state)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=pulse:chat:
REDIS_SESSION_TTL=3600

# -----------------------------------------------------------------------------
# OpenAI / LLM Configuration (REQUIRED for AI features)
# -----------------------------------------------------------------------------
# Your OpenAI API key - REQUIRED for LLM functionality
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Custom OpenAI API base URL (for Azure OpenAI or proxies)
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Model configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# Vertex AI (Google Cloud) - Optional alternative to direct OpenAI/Google AI key
# -----------------------------------------------------------------------------
# Enable this mode when you want to use Gemini through Vertex AI and Google Cloud
# credits. In this mode, the agent will use Application Default Credentials (ADC)
# from GOOGLE_APPLICATION_CREDENTIALS or another ADC source supported by Google.
#
# Official docs:
# - https://cloud.google.com/vertex-ai/generative-ai/docs/start/openai
# - https://cloud.google.com/docs/authentication/application-default-credentials
#
# VERTEX_AI_ENABLED=true
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=global
#
# For Vertex AI OpenAI-compatible mode, use a Vertex model id such as:
# OPENAI_MODEL=google/gemini-2.5-flash
#
# Choose one authentication approach:
# 1. ADC / Secret File:
# GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/vertex-service-account.json
#
# 2. Raw JSON in env (handy on Render):
# VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# -----------------------------------------------------------------------------
# JWT Authentication (REQUIRED in production)
# -----------------------------------------------------------------------------
# Secret key for JWT signing - MUST be a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Pulse Backend API
# -----------------------------------------------------------------------------
PULSE_BACKEND_URL=http://localhost:8080
PULSE_BACKEND_TIMEOUT=30.0

# -----------------------------------------------------------------------------
# Action Generation
# -----------------------------------------------------------------------------
MAX_ACTIONS_PER_RESPONSE=4
ACTIONS_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Conversation State
# -----------------------------------------------------------------------------
MAX_HISTORY_LENGTH=10
SESSION_TIMEOUT_SECONDS=3600
